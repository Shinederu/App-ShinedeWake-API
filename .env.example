BASE_URL=https://wake.shinederu.ch
AUTH_API_BASE=https://api.shinederu.ch/auth/
AUTH_PORTAL_URL=https://auth.shinederu.ch
CORS_ALLOWED_ORIGINS=https://wake.shinederu.ch,http://localhost:5173,http://127.0.0.1:5173
WAKE_DEFAULT_BROADCAST=192.168.10.255
WAKE_DEFAULT_PORT=9
WAKE_LOG_ENABLED=1
WAKE_LOG_FILE=
WAKE_PING_ENABLED=1
WAKE_PING_TIMEOUT_SECONDS=1
WAKE_PING_COMMAND=ping
WAKE_MERCURE_HUB_URL=https://mercure.shinederu.ch/.well-known/mercure
WAKE_MERCURE_PUBLISH_URL=http://mercure/.well-known/mercure
WAKE_MERCURE_PUBLISHER_JWT_KEY=
WAKE_MERCURE_TOPIC_BASE=https://api.shinederu.ch/wake/topics
WAKE_MERCURE_EVENTS_PRIVATE=1
WAKE_MERCURE_PUBLISH_TIMEOUT_SECONDS=3

WAKE_DB_TYPE=mysql
WAKE_DB_HOST=127.0.0.1
WAKE_DB_PORT=3306
WAKE_DB_NAME=ShinedeCore
